+/* ============================================================ */
+
+static void draw_menu(const char **items, int count, const char *title)
+{
+    rb->lcd_setfont(FONT_SYSFIXED);
+    rb->lcd_set_background(LCD_RGBPACK(255, 255, 255));
+    rb->lcd_clear_display();
+
+    rb->lcd_set_foreground(LCD_RGBPACK(50, 50, 50));
+    rb->lcd_fillrect(0, 0, SCREEN_W, TITLE_H);
+    rb->lcd_set_background(LCD_RGBPACK(50, 50, 50));
+    rb->lcd_set_foreground(LCD_RGBPACK(255, 255, 255));
+
+    struct mp3entry *track = rb->audio_current_track();
+    if (rb->audio_status() && track && track->title) {
+        rb->lcd_putsxy(12, 3, title);
+        rb->lcd_putsxy(12, 17, track->title);
+    } else {
+        rb->lcd_putsxy(12, 12, title);
+    }
+
+    int visible = (count < VISIBLE) ? count : VISIBLE;
+    for (int i = 0; i < visible; i++) {
+        int idx = top[level] + i;
+        if (idx >= count) break;
+        int y = TITLE_H + i * ITEM_H;
+
+        if (idx == sel[level]) {
+            rb->lcd_set_foreground(LCD_RGBPACK(43, 114, 215));
+            rb->lcd_fillrect(0, y, SCREEN_W, ITEM_H);
+            rb->lcd_set_background(LCD_RGBPACK(43, 114, 215));
+            rb->lcd_set_foreground(LCD_RGBPACK(255, 255, 255));
+        } else {
+            rb->lcd_set_background(LCD_RGBPACK(255, 255, 255));
+            rb->lcd_set_foreground(LCD_RGBPACK(30, 30, 30));
+        }
+
+        rb->lcd_putsxy(15, y + 9, items[idx]);
+        rb->lcd_putsxy(SCREEN_W - 16, y + 9, ">");
+
+        rb->lcd_set_foreground(LCD_RGBPACK(210, 210, 210));
+        rb->lcd_hline(0, SCREEN_W, y + ITEM_H - 1);
+    }
+
+    rb->lcd_update();
+}
+
+enum plugin_status plugin_start(const void *parameter)
+{
+    int *dest = (int*)parameter;
+
+    while (true) {
+        bool playing = rb->audio_status() != 0;
+        const char **items;
+        int count;
+        const char *title;
+
+        if (level == 0) {
+            items = playing ? root_items_playing : root_items;
+            count = playing ? (ROOT_COUNT + 1) : ROOT_COUNT;
+            title = "iPod";
+            if (sel[0] >= count) sel[0] = count - 1;
+        } else {
+            items = music_items;
+            count = MUSIC_COUNT;
+            title = "Music";
+        }
+
+        draw_menu(items, count, title);
+
+        int btn = rb->button_get(true);
+
+        if (btn == SYS_USB_CONNECTED)
+            return PLUGIN_USB_CONNECTED;
+
+        /* Continuous wheel rotation posts repeat-flagged events (the first
+         * event of a touch is plain, every further one has BUTTON_REPEAT
+         * set), so match with the flag masked off or we only ever move one
+         * item per touch. Step count comes from the driver's velocity. */
+        int base = btn & ~BUTTON_REPEAT;
+        if (base == BUTTON_SCROLL_BACK || base == BUTTON_SCROLL_FWD) {
+            int step = wheel_steps();
+            int next = sel[level] + (base == BUTTON_SCROLL_FWD ? step : -step);
+            if (next < 0) next = 0;
+            if (next >= count) next = count - 1;
+            sel[level] = next;
+            if (sel[level] < top[level])
+                top[level] = sel[level];
+            if (sel[level] >= top[level] + VISIBLE)
+                top[level] = sel[level] - VISIBLE + 1;
+        } else if (btn == BUTTON_SELECT) {
+            if (level == 0) {
+                if (playing && sel[0] == 0) {
+                    if (dest) *dest = DEST_WPS;
+                    return PLUGIN_OK;
+                }
+                int item = sel[0] - (playing ? 1 : 0);
+                switch (item) {
+                    case 0: level = 1; break;                                   /* Music   */
+                    case 1: if (dest) *dest = DEST_FILEBROWSER; return PLUGIN_OK; /* Photos  */
+                    case 2: if (dest) *dest = DEST_FILEBROWSER; return PLUGIN_OK; /* Podcasts*/
+                    case 3: if (dest) *dest = DEST_PLUGINS;     return PLUGIN_OK; /* Extras  */
+                    case 4: {                                                    /* Wrapped */
+                        int st = wrapped_show();
+                        if (st == PLUGIN_USB_CONNECTED) return PLUGIN_USB_CONNECTED;
+                        break;
+                    }
+                    case 5: if (dest) *dest = DEST_SETTINGS;    return PLUGIN_OK; /* Settings*/
+                    case 6: if (dest) *dest = DEST_SHUFFLE;     return PLUGIN_OK; /* Shuffle */
+                    default: break;
+                }
+            } else if (level == 1) {
+                if (dest) *dest = (sel[1] == 2 || sel[1] == 5) ? DEST_FILEBROWSER : DEST_DBBROWSER;
                 return PLUGIN_OK;
-            default:
-                if (rb->default_event_handler(button) == SYS_USB_CONNECTED)
-                    return PLUGIN_USB_CONNECTED;
+            }
+        } else if (btn == BUTTON_MENU) {
+            if (level > 0) level--;
+            else return PLUGIN_OK;
         }
     }
-    return PLUGIN_OK;
 }
