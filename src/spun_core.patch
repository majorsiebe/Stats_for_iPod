index 8102f8d917..20596b4092 100644
--- a/apps/playback.c
+++ b/apps/playback.c
@@ -365,6 +365,168 @@ static unsigned int position_key = 0;
 static int playback_log_handle = 0; /* core_alloc handle for playback log buffer */
 #endif
 
+#include "playback_sig.h"
+
+/* Running signature over every byte this device has written to the
+ * playback-log family, so Wrapped can tell device-written history from
+ * PC-edited history. State mirrors the sidecar file at all times: it is
+ * only advanced when bytes actually reach the disk. */
+static struct pbl_sig pbl_sig;
+static bool pbl_sig_ready = false;
+
+/* a crash between the log write and the sig write can orphan at most one
+ * flush; anything bigger than that was not written by us */
+#if (CONFIG_STORAGE & STORAGE_ATA)
+#define PBL_SIG_HEAL_MAX (PLAYBACK_LOG_BUFSZ + MAX_PATH + 64)
+#else
+#define PBL_SIG_HEAL_MAX (MAX_PATH + 64)
+#endif
+
+static void pbl_sig_store(void)
+{
+    int fd = open(PBL_SIG_PATH, O_WRONLY|O_CREAT|O_TRUNC, 0666);
+    if (fd < 0)
+        return;
+    write(fd, &pbl_sig, sizeof(pbl_sig));
+    close(fd);
+}
+
+/* hash bytes [skip, skip+want) of the family concatenation (numbered logs
+ * ascending, live log last - the log readers' order) into *h; returns the
+ * number of bytes actually hashed. want == UINT64_MAX hashes to the end. */
+static uint64_t pbl_family_hash(uint64_t skip, uint64_t want, uint64_t *h)
+{
+    char path[MAX_PATH];
+    unsigned char buf[512];
+    uint64_t done = 0;
+
+    for (int n = 1; want > 0; n++) {
+        if (n <= 9999)
+            snprintf(path, sizeof(path), ROCKBOX_DIR "/playback_%04d.log", n);
+        int fd = open(n <= 9999 ? path : PLAYBACK_LOG_PATH, O_RDONLY);
+        if (fd < 0) {
+            if (n <= 9999) {         /* numbered run ended; the live log */
+                n = 10000 - 1;       /* is the final link (loop n++)     */
+                continue;
+            }
+            break;
+        }
+        ssize_t r;
+        while (want > 0 && (r = read(fd, buf, sizeof(buf))) > 0) {
+            size_t off = 0, use = (size_t)r;
+            if (skip) {
+                if (skip >= (uint64_t)r) { skip -= r; continue; }
+                off = (size_t)skip;
+                use -= off;
+                skip = 0;
+            }
+            if ((uint64_t)use > want)
+                use = (size_t)want;
+            *h = pbl_hash_step(*h, buf + off, use);
+            done += use;
+            want -= use;
+        }
+        close(fd);
+        if (n > 9999)
+            break;
+    }
+    return done;
+}
+
+static uint64_t pbl_family_size(void)
+{
+    char path[MAX_PATH];
+    uint64_t total = 0;
+    for (int n = 1; n <= 9999; n++) {
+        snprintf(path, sizeof(path), ROCKBOX_DIR "/playback_%04d.log", n);
+        int fd = open(path, O_RDONLY);
+        if (fd < 0)
+            break;
+        total += filesize(fd);
+        close(fd);
+    }
+    int fd = open(PLAYBACK_LOG_PATH, O_RDONLY);
+    if (fd >= 0) {
+        total += filesize(fd);
+        close(fd);
+    }
+    return total;
+}
+
+/* Load or establish the signature chain; call before any signed write.
+ * Idempotent, and deliberately NOT INIT_ATTR: enabling logging at runtime
+ * lands here from add_playbacklog long after init sections are gone. */
+static void pbl_sig_init(void)
+{
+    if (pbl_sig_ready)
+        return;
+    pbl_sig_ready = true;
+
+    int fd = open(PBL_SIG_PATH, O_RDONLY);
+    bool have = false;
+    if (fd >= 0) {
+        have = (read(fd, &pbl_sig, sizeof(pbl_sig)) == sizeof(pbl_sig)
+                && pbl_sig.magic == PBL_SIG_MAGIC);
+        close(fd);
+    }
+
+    uint64_t actual = pbl_family_size();
+    if (!have) {
+        /* first run with a signing build: adopt what's here as-is - but
+         * only if this device never had a sig. A sig that has been seen
+         * and is now gone was deleted; the re-bless carries the mark. */
+        uint32_t seen = 0;
+        fd = open(CHEAT_DAT_PATH, O_RDONLY);
+        if (fd >= 0) {
+            uint32_t m = 0, f = 0;
+            if (read(fd, &m, 4) == 4 && m == CHEAT_DAT_MAGIC
+                && read(fd, &f, 4) == 4)
+                seen = f & CHEAT_F_SIG_SEEN;
+            close(fd);
+        }
+        pbl_sig.magic  = PBL_SIG_MAGIC;
+        pbl_sig.flags  = seen ? PBL_SIG_TAINTED : 0;
+        pbl_sig.hash   = PBL_HASH_BASIS;
+        pbl_sig.nbytes = pbl_family_hash(0, UINT64_MAX, &pbl_sig.hash);
+        pbl_sig_store();
+        return;
+    }
+    if (actual == pbl_sig.nbytes)
+        return;                      /* normal boot: chain state is current */
+
+    if (actual > pbl_sig.nbytes
+        && actual - pbl_sig.nbytes <= PBL_SIG_HEAL_MAX) {
+        /* small unsigned tail: probably our own flush whose sig update was
+         * lost to a crash. If the signed prefix still checks out, re-adopt
+         * the tail; if not, the history itself was rewritten. */
+        uint64_t h = PBL_HASH_BASIS;
+        pbl_family_hash(0, pbl_sig.nbytes, &h);
+        if (h == pbl_sig.hash) {
+            pbl_sig.nbytes += pbl_family_hash(pbl_sig.nbytes, UINT64_MAX,
+                                              &pbl_sig.hash);
+            pbl_sig_store();
+            return;
+        }
+    }
+
+    /* the chain is broken in a way we didn't cause: remember that forever
+     * and resync so the log keeps verifying (as tainted) from here on */
+    pbl_sig.flags |= PBL_SIG_TAINTED;
+    pbl_sig.hash   = PBL_HASH_BASIS;
+    pbl_sig.nbytes = pbl_family_hash(0, UINT64_MAX, &pbl_sig.hash);
+    pbl_sig_store();
+}
+
+/* account for bytes that just hit the log file */
+static void pbl_sig_extend(const void *data, size_t n)
+{
+    if (n == 0)
+        return;
+    pbl_sig.hash    = pbl_hash_step(pbl_sig.hash, data, n);
+    pbl_sig.nbytes += n;
+    pbl_sig_store();
+}
+
