+/* Apple-iPod-style menu; the Wrapped stats live in wrapped_core.h and are
+ * also built standalone as wrapped.rock */
+
+#define ITEM_H    33
+#define TITLE_H   32
+#define SCREEN_W  320
+#define SCREEN_H  240
+
+#define DEST_FILEBROWSER 1
+#define DEST_DBBROWSER   2
+#define DEST_SETTINGS    3
+#define DEST_SHUFFLE     4
+#define DEST_PLUGINS     5
+#define DEST_WPS         6
+
+static const char *root_items[] = {
+    "Music", "Photos", "Podcasts", "Extras", "Spun", "Settings", "Shuffle Songs"
+};
+static const char *root_items_playing[] = {
+    "Now Playing", "Music", "Photos", "Podcasts", "Extras", "Spun", "Settings", "Shuffle Songs"
+};
+static const char *music_items[] = {
+    "Artists", "Albums", "Songs", "Genres", "Composers", "Playlists"
+};
+#define MUSIC_COUNT 6
+#define ROOT_COUNT  7   /* not playing */
+#define VISIBLE     ((SCREEN_H - TITLE_H) / ITEM_H)
+
+static int level = 0;
+static int sel[2] = {0, 0};
+static int top[2] = {0, 0};
+
+#include "wrapped_core.h"
