+/* custom addition (this build): while a background achievement toast is on
+ * screen, LCD pushes from every thread except the freezing one are dropped
+ * (checked in the target lcd driver; auto-expires after 5 s as a safety
+ * net so a dying plugin can never freeze the display for good). */
+volatile unsigned int lcd_freeze_thread = 0;
+volatile long lcd_freeze_tick = 0;
+
+static void lcd_freeze_others(bool freeze)
+{
+    if (freeze) {
+        lcd_freeze_tick = current_tick;
+        lcd_freeze_thread = thread_self();
+    } else {
+        lcd_freeze_thread = 0;
+    }
+}
